<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="{i18n>processClaimDialogTitle}"
        type="Message"
        contentWidth="420px">

        <content>
            <VBox class="sapUiSmallMargin">

                <MessageStrip
                    text="{i18n>processClaimDialogMessage}"
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginBottom" />

                <Label
                    text="{i18n>processClaimDateLabel}"
                    design="Bold"
                    class="sapUiSmallMarginTop" />

                <DatePicker
                    id="resolutionDatePicker"
                    value="{
                        path: '/processClaimDate',
                        type: 'sap.ui.model.type.Date',
                        formatOptions: { pattern: 'dd.MM.yyyy' }
                    }"
                    displayFormat="dd.MM.yyyy"
                    width="100%"
                    class="sapUiTinyMarginTop" />

            </VBox>
        </content>

        <beginButton>
            <Button
                text="{i18n>processClaimConfirm}"
                type="Emphasized"
                press="onProcessClaimConfirm" />
        </beginButton>

        <endButton>
            <Button
                text="{i18n>processClaimCancel}"
                press="onProcessClaimCancel" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>
