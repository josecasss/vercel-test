<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <SelectDialog
        title="{i18n>valueHelpCustomerTitle}"
        confirm="onCustomerConfirm"
        cancel="onCustomerCancel"
        search="onCustomerSearch"
        items="{/Customers}">

        <StandardListItem
            title="{Key}"
            description="{Text}"
            type="Active" />

    </SelectDialog>

</core:FragmentDefinition>
